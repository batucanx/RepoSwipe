<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ (Android 12+) cloud backup / device-to-device transfer rules. The GitHub token is
     encrypted with a key that lives in the Android Keystore and never leaves the device, so a
     restored copy of this file can never be decrypted on another device — excluding it here
     avoids shipping undecryptable ciphertext across a restore instead of just re-prompting login. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/auth_prefs.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/auth_prefs.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
